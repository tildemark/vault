{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VAULT",
  "version": "0.1.0",
  "identifier": "com.vault.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VAULT – Virtual Archive & Upload List Tracker",
        "width": 1340,
        "height": 860,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/vault-icon-1024.png"
    ],
    "resources": []
  }
}
